{
  "expo": {
    "name": "clash",
    "slug": "clash",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/clash.png",
    "scheme": "clash",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "package": "com.officialme.com.clash"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/clashh.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#080810",
          "dark": {
            "backgroundColor": "#080810"
          }
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9ff2b928-c158-45f5-8f03-884a10ecf3e7"
      }
    }
  }
}
